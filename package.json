{
  "name": "orchestra",
  "version": "1.0.0",
  "description": "Orchestra - 基于 Claude Coordinator 模式的四阶段多 Agent 协作框架",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "example:bugfix": "ts-node examples/real-world-examples.ts --bugfix",
    "example:feature": "ts-node examples/real-world-examples.ts --feature",
    "example:perf": "ts-node examples/real-world-examples.ts --perf",
    "example:security": "ts-node examples/real-world-examples.ts --security",
    "example:migration": "ts-node examples/real-world-examples.ts --migration",
    "example:all": "ts-node examples/real-world-examples.ts --all",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\""
  },
  "keywords": [
    "orchestra",
    "multi-agent",
    "workflow",
    "claude-coordinator",
    "ai-orchestration",
    "openclaw"
  ],
  "author": "AI System Architect",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/orchestra"
  },
  "bugs": {
    "url": "https://github.com/openclaw/orchestra/issues"
  },
  "homepage": "https://github.com/openclaw/orchestra#readme"
}
